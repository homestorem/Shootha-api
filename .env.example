# Copy to .env (never commit .env)

# --- Express API (server/index.ts) — npm run dev / npm run server:dev ---
PORT=4001
# Same machine (Expo web): localhost is fine.
# Physical device on Wi‑Fi: use your PC LAN IP for EXPO_PUBLIC_API_URL (and keep EXPO_PUBLIC_DEV_LAN_HOST for localhost rewrite on native).
# EXPO_PUBLIC_DEV_LAN_HOST=192.168.1.10
# EXPO_PUBLIC_API_URL=http://192.168.1.10:4001

# Guest mode — optional (see constants/guestAccess.ts)
# GUEST_FULL_ACCESS=

# OTP via Express: /api/auth/send-otp — do not set EXPO_PUBLIC_OTP_API_URL unless you use server/index.js (npm run server:otp)
# EXPO_PUBLIC_OTP_API_URL=http://192.168.1.10:4000

# OTP IQ (Express sends SMS when key is set)
# OTP_IQ_API_KEY=

# Firebase Admin — promo routes
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
# PROMO_JWT_SECRET=

# Firebase Web SDK
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=

# Cloudinary
# EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
# EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# --- Wayl (server only — never ship WAYL_API_KEY to the app) ---
WAYL_BASE_URL=https://api.thewayl.com
# WAYL_API_KEY=
# Checkout path (links API uses webhook fields below)
# WAYL_CHECKOUT_PATH=/api/v1/links
#
# Public URL Wayl can call (must not be localhost for link creation unless you override with LAN below).
# Production: https://your-domain.com/api/payments/wayl/webhook
# Local + LAN: http://192.168.x.x:4001/api/payments/wayl/webhook (Wayl cloud cannot reach LAN — use ngrok for real callbacks).
# WAYL_WEBHOOK_URL=http://192.168.1.10:4001/api/payments/wayl/webhook
#
# If WAYL_WEBHOOK_URL uses localhost, the server replaces host with EXPO_PUBLIC_DEV_LAN_HOST / DEV_LAN_HOST / WAYL_PUBLIC_HOST.
# DEV_LAN_HOST=192.168.1.10
# WAYL_WEBHOOK_SECRET=change-me
