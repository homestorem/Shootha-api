{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "npm run server:dev",
    "backend": "npm run server:dev",
    "start": "node server_dist/index.js",
    "build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=server_dist/index.js",
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "server:dev": "cross-env NODE_ENV=development nodemon --watch server --ext ts --exec tsx server/index.ts",
    "server:start": "cross-env NODE_ENV=development tsx server/index.ts",
    "server:otp": "node server/index.js",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=server_dist/index.js",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "start:lan": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --host lan --max-workers 1",
    "start:lan:8082": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --host lan --port 8082 --max-workers 1",
    "start:lan:8082:clear": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --host lan --port 8082 --max-workers 1 -c",
    "start:tunnel": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --tunnel --max-workers 1",
    "start:mem": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --host lan --max-workers 1 -c",
    "expo:start:offline": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --offline --host lan --max-workers 1",
    "expo:start:offline:clear": "node --max-old-space-size=8192 ./node_modules/expo/bin/cli start --offline --host lan --max-workers 1 -c",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo-google-fonts/cairo": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "^5.83.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@ungap/structured-clone": "^1.3.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.0.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^12.7.0",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^26.0.4",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "node-cron": "^4.2.1",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.2",
    "react-leaflet": "^5.0.0",
    "react-native": "0.81.5",
    "react-native-date-picker": "^5.0.13",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "three": "^0.183.2",
    "tsx": "^4.20.6",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@react-native-community/cli": "^20.1.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "~19.1.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "nodemon": "^3.1.14",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
